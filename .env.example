# ============================================
# Configuration Voice Transcriptor
# ============================================
# Ce fichier contient la configuration de l'application
# Copiez-le en .env et remplissez vos clés API
# ============================================

# --------------------------------------------
# PROVIDER DE TRANSCRIPTION
# --------------------------------------------
# Choix du provider : 'openai' ou 'mistral'
# - openai : Utilise GPT-4o Transcribe (nécessite OPENAI_API_KEY)
# - mistral : Utilise Voxtral Mini Transcribe (nécessite MISTRAL_API_KEY)
TRANSCRIPTION_PROVIDER=openai

# --------------------------------------------
# CLÉS API
# --------------------------------------------
# OpenAI API Key - Obtenez-la sur https://platform.openai.com/api-keys
# Nécessaire si TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Mistral API Key - Obtenez-la sur https://console.mistral.ai/
# Nécessaire si TRANSCRIPTION_PROVIDER=mistral
MISTRAL_API_KEY=your_mistral_api_key_here

# --------------------------------------------
# CONFIGURATION AUDIO (optionnel)
# --------------------------------------------
# Taux d'échantillonnage audio (Hz)
# Valeurs courantes : 16000, 22050, 44100, 48000
# Défaut : 44100
# SAMPLE_RATE=44100

# Nombre de canaux audio
# 1 = Mono, 2 = Stéréo
# Défaut : 1
# CHANNELS=1

# --------------------------------------------
# CONFIGURATION MISTRAL (optionnel)
# --------------------------------------------
# Modèle Voxtral à utiliser
# - voxtral-mini-latest : Dernière version (recommandé)
# - voxtral-mini-2602 : Version spécifique
# Défaut : voxtral-mini-latest
# MISTRAL_MODEL=voxtral-mini-latest

# Langue de transcription (optionnel)
# Si non spécifié, détection automatique
# Exemples : en, fr, de, es, it, pt, ru, ja, ko, zh, ar, nl
# MISTRAL_LANGUAGE=fr

# Context biasing (optionnel)
# Liste de mots/phrases séparés par des virgules pour guider la transcription
# Utile pour les noms propres ou termes techniques
# MISTRAL_CONTEXT_BIAS=Paris,Marseille,Lyon, intelligence artificielle

# --------------------------------------------
# NOTES
# --------------------------------------------
# 1. Ne partagez jamais ce fichier avec vos clés API !
# 2. Le fichier .env est ignoré par git (voir .gitignore)
# 3. Vous pouvez définir les variables d'environnement directement
#    dans votre shell si vous préférez
